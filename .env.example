# Optional: TfL Unified API app key for higher rate limits (server-side only).
# The app works without one. Get a free key at https://api-portal.tfl.gov.uk/
TFL_APP_KEY=

# Required ONLY for the /photoreal route (Google Photorealistic 3D Tiles).
# Create a key in Google Cloud Console with the "Map Tiles API" enabled and
# billing turned on, then put it here in .env.local (NOT committed). Because it
# ships to the browser, restrict it by HTTP referrer.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
